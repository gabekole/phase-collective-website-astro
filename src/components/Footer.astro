---
const year = new Date().getFullYear();

const cities = ['New York', 'Philadelphia', 'Los Angeles'];
---

<footer class="site-footer">
  <div class="footer-inner">

    <div class="footer-top">
      <span class="footer-logo">Phase</span>
      <div class="footer-cities">
        {cities.map((city, i) => (
          <span class="footer-city" style={`--i:${i}`}>{city}</span>
        ))}
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© {year}. All rights reserved.</span>
      <a href="mailto:contact@phasecollective.com" class="footer-email">contact@phasecollective.com</a>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--gray-4);
    padding: clamp(32px, 5vw, 56px) var(--section-px);
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(28px, 4vw, 48px);
  }

  /* Top row */
  .footer-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-logo {
    font-size: 11px;
    font-weight: var(--weight-med);
    letter-spacing: 0.28em;
    color: var(--gray-3);
    text-transform: uppercase;
  }

  .footer-cities {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .footer-city {
    font-size: 11px;
    font-weight: var(--weight-light);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gray-3);
  }

  .footer-city:not(:last-child)::after {
    content: ' — ';
    white-space: pre;
    color: var(--gray-4);
  }

  /* Bottom row */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    padding-top: clamp(20px, 3vw, 32px);
    border-top: 1px solid var(--gray-4);
  }

  .footer-copy {
    font-size: 11px;
    font-weight: var(--weight-light);
    letter-spacing: 0.06em;
    color: var(--gray-3);
  }

  .footer-email {
    font-size: 11px;
    font-weight: var(--weight-light);
    letter-spacing: 0.06em;
    color: var(--gray-3);
    text-decoration: none;
    position: relative;
    transition: color 0.2s ease;
  }

  .footer-email::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gray-3);
    transition: width 0.3s var(--ease-out);
  }

  .footer-email:hover {
    color: var(--white);
  }

  .footer-email:hover::after {
    width: 100%;
    background: var(--white);
  }

  @media (max-width: 480px) {
    .footer-top,
    .footer-bottom {
      flex-direction: column;
      gap: 12px;
    }
  }
</style>