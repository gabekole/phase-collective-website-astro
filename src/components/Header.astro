---
---

<header class="site-header">
  <nav class="site-nav" aria-label="Main navigation">
    <a href="/" class="nav-logo" aria-label="Phase — home">
      <img
        src="/images/Phase_logo_invert.svg"
        alt="Phase"
        class="nav-logo-img"
        width="80"
        height="32"
      />
    </a>

    <ul class="nav-links" role="list">
      <li><a href="#about"   class="nav-link">About</a></li>
      <li><a href="#contact" class="nav-link">Contact</a></li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-h);
    /* Subtle blur backdrop so text underneath doesn't clash */
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--gray-4);
  }

  .site-nav {
    max-width: 1280px;
    margin: 0 auto;
    height: 100%;
    padding: 0 var(--section-px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav-logo-img {
    /* The SVG has built-in padding so we clip it visually */
    height: 38px;
    width: auto;
    /* Nudge left to optically align with page edge */
    margin-left: -4px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-size: 11px;
    font-weight: var(--weight-med);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gray-2);
    text-decoration: none;
    position: relative;
    transition: color 0.2s ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--white);
    transition: width 0.3s var(--ease-out);
  }

  .nav-link:hover {
    color: var(--white);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  @media (max-width: 480px) {
    .nav-links {
      gap: 20px;
    }

    .nav-link {
      font-size: 10px;
    }
  }
</style>